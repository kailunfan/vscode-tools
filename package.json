{
  "name": "vscode-tools",
  "displayName": "开发者工具集",
  "description": "集成常用开发工具：时间戳互转等",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vscode-tools.encodeToUnixSeconds",
    "onCommand:vscode-tools.timestampToTimeString"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-tools.encodeToUnixSeconds",
        "title": "转换为时间戳"
      },
      {
        "command": "vscode-tools.timestampToTimeString",
        "title": "转换为时间字符串"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vscode-tools.timestampToTimeString",
          "group": "navigation@7",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "vscode-tools.encodeToUnixSeconds",
          "group": "navigation@8",
          "when": "editorTextFocus && editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.3.3"
  }
}
